# ============================================================
# MindEase AI — Root .gitignore
# ============================================================

# --- Environment & secrets ---
.env
.env.local
.env.*.local
backend/.env
frontend/.env
frontend/.env.local
*.pem
*.key
cookies.txt

# Keep example env files (do NOT ignore):
# !backend/.env.example
# !backend/.env.free.example
# !frontend/.env.example

# --- Python / Backend ---
backend/.venv/
backend/__pycache__/
backend/**/__pycache__/
backend/*.py[cod]
backend/*.egg-info/
backend/.pytest_cache/
backend/.mypy_cache/
backend/.ruff_cache/
backend/dist/
backend/build/
backend/*.egg

# --- Node / Frontend ---
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.turbo/
frontend/.vercel/
frontend/coverage/
frontend/*.tsbuildinfo

# --- Databases (local dev data) ---
*.db
*.sqlite
*.sqlite3
mindease.db
backend/mindease.db

# --- Logs & runtime output ---
*.log
backend/backend-dev.err.log
backend/backend-dev.out.log
frontend/frontend-dev.err.log
frontend/frontend-dev.out.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- OS & IDE ---
.DS_Store
Thumbs.db
Desktop.ini
.idea/
.vscode/
*.swp
*.swo
*~

# --- Cursor / local tooling ---
.cursor/

# --- Uploads & generated artifacts ---
uploads/
tmp/
temp/
.cache/

# --- Test / coverage ---
coverage/
htmlcov/
.coverage
.nyc_output/
