# MindEase zero-budget AI configuration
# Copy this file to backend/.env and paste only the keys you want to use.

# Provider fallback order for text generation:
# 1. Gemini
# 2. Groq
# 3. OpenRouter
# 4. Local heuristic fallback
AI_PROVIDER_PRIORITY=gemini,groq,openrouter

# Google Gemini: best free default for translator, replies, journal summaries, and embeddings.
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Groq: best free default for voice transcription and fast text fallback.
GROQ_API_KEY=YOUR_GROQ_API_KEY
GROQ_MODEL=llama-3.1-8b-instant
GROQ_VOICE_MODEL=whisper-large-v3-turbo

# OpenRouter: backup provider. Use only models ending in :free for zero-budget mode.
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY
OPENROUTER_MODEL=google/gemma-3-27b-it:free
APP_NAME=MindEase AI
APP_PUBLIC_URL=http://localhost:3000
APP_USER_AGENT=MindEaseAI/1.0 (+http://localhost)

# Database: leave empty for local SQLite. Set only if you use Supabase/Postgres.
# DATABASE_URL=

# Auth
JWT_SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET
