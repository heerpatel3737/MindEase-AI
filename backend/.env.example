# ============================================================
# MindEase AI — Backend Environment Variables
# Copy to backend/.env and fill in your values.
# NEVER commit backend/.env to GitHub.
# ============================================================

# --- AI Provider Priority ---
# Comma-separated fallback order. Local heuristics run if all fail.
AI_PROVIDER_PRIORITY=gemini,groq,openrouter

# --- Google Gemini (text + embeddings) ---
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_EMBEDDING_MODEL=text-embedding-004

# --- Groq (fast text fallback + voice transcription) ---
# Get key: https://console.groq.com/keys
GROQ_API_KEY=YOUR_GROQ_API_KEY
GROQ_MODEL=llama-3.1-8b-instant
GROQ_VOICE_MODEL=whisper-large-v3-turbo

# --- OpenRouter (optional backup; use :free models for zero cost) ---
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY
OPENROUTER_MODEL=google/gemma-3-27b-it:free

# --- App metadata (sent to OpenRouter headers) ---
APP_NAME=MindEase AI
APP_PUBLIC_URL=http://localhost:3000
APP_USER_AGENT=MindEaseAI/1.0 (+http://localhost)

# --- Database ---
# Leave empty for local SQLite (backend/mindease.db).
# For production, use Supabase/Railway/Render Postgres connection string:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=

# --- Authentication ---
# REQUIRED in production. Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET

# --- CORS (comma-separated frontend origins) ---
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Cookies ---
# Set true in production (HTTPS only)
COOKIE_SECURE=false

# --- Environment ---
# Set to "production" to hide password-reset tokens from API responses
ENVIRONMENT=development
